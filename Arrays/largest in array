class Solution {
    public static int largest(int[] arr) {
        int max = arr[0];

        for (int num : arr) {   // enhanced for-loop (clean)
            if (num > max) {
                max = num;
            }
        }

        return max;
    }

    public static void main(String[] args) {
        int[] arr = {1, 8, 7, 56, 90};
        System.out.println(largest(arr)); // 90
    }
}
