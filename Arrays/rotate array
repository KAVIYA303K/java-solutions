class Solution {
    public void rotateArr(int[] arr, int d) {
        int n = arr.length;
        
        // Edge case
        if (n == 0) return;

        // Handle d > n
        d = d % n;
        
        // Step 1: Reverse first d elements
        reverse(arr, 0, d - 1);
        
        // Step 2: Reverse remaining elements
        reverse(arr, d, n - 1);
        
        // Step 3: Reverse whole array
        reverse(arr, 0, n - 1);
    }
    
    private void reverse(int[] arr, int start, int end) {
        while (start < end) {
            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;
            
            start++;
            end--;
        }
    }
}
